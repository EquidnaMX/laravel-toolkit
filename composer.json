{
  "name": "equidna/laravel-toolkit",
  "description": "Multi-context Laravel helpers, middleware, and utilities.",
  "version": "2.0.0",
  "type": "library",
  "license": "MIT",
  "authors": [
    {
      "name": "Gabriel Ruelas",
      "email": "gruelasjr@gmail.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "laravel/framework": "^12.0 || ^13.0",
    "laravel/helpers": "^1.7",
    "illuminate/support": "^12.0 || ^13.0"
  },
  "require-dev": {
    "squizlabs/php_codesniffer": "*",
    "larastan/larastan": "*",
    "phpunit/phpunit": "^9.6 || ^11.5 || ^12.5 || ^13.2"
  },
  "autoload": {
    "psr-4": {
      "Equidna\\Toolkit\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Equidna\\Toolkit\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Equidna\\Toolkit\\Providers\\EquidnaLaravelToolkitServiceProvider"
      ]
    }
  }
}
